# Demux GPIO configuration options

# Copyright (c) 2026 The ZMK Contributors
# SPDX-License-Identifier: MIT

menuconfig GPIO_DEMUX
    bool "GPIO Demux Driver"
    default y
    depends on DT_HAS_ZMK_GPIO_DEMUX_ENABLED
    select HAS_DTS_GPIO
    help
      Enable driver for demux GPIO outputs.

if GPIO_DEMUX

config GPIO_DEMUX_INIT_PRIORITY
    int "Init priority"
    default 75
    help
      Device driver initialization priority.

endif #GPIO_DEMUX
