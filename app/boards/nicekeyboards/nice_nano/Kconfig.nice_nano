config BOARD_NICE_NANO
    select SOC_NRF52840_QIAA
    select ZMK_BOARD_COMPAT if BOARD_NICE_NANO_NRF52840_ZMK || BOARD_NICE_NANO_NRF52840_ZMK_DEBUG
    imply RETAINED_MEM if BOARD_NICE_NANO_NRF52840_ZMK || BOARD_NICE_NANO_NRF52840_ZMK_DEBUG
    imply RETENTION if BOARD_NICE_NANO_NRF52840_ZMK || BOARD_NICE_NANO_NRF52840_ZMK_DEBUG
    imply RETENTION_BOOT_MODE if BOARD_NICE_NANO_NRF52840_ZMK || BOARD_NICE_NANO_NRF52840_ZMK_DEBUG
