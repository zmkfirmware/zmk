# Note: CONFIG_BOARD_DERIVATIVE_REV_A and SOC configs are auto-set by the build system

CONFIG_ARM_MPU=y
CONFIG_PINCTRL=y
CONFIG_GPIO=y

CONFIG_SPI=y
CONFIG_NRFX_SPIM3=y
CONFIG_SPI_NRFX=y
CONFIG_SPI_NRFX_RAM_BUFFER_SIZE=8

CONFIG_USE_DT_CODE_PARTITION=y
CONFIG_BUILD_OUTPUT_UF2=y

CONFIG_MPU_ALLOW_FLASH_WRITE=y
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y

# Required by ZMK_LED_MAP; underglow LEDs are not populated on this board
CONFIG_ZMK_RGB_UNDERGLOW=y

# Per-key RGB + indicators
CONFIG_ZMK_LED_MAP=y
CONFIG_ZMK_LED_MAP_PER_KEY_BRT_MAX=10
CONFIG_ZMK_LED_MAP_INDICATOR_BRT_MAX=5
CONFIG_ZMK_LED_MAP_EFF_START=6
CONFIG_ZMK_HID_INDICATORS=y

# 1000 Hz USB polling rate
CONFIG_USB_HID_POLL_INTERVAL_MS=1

CONFIG_ZMK_USB=y
CONFIG_ZMK_BLE=y
CONFIG_ZMK_STUDIO=y
CONFIG_ZMK_SLEEP=y
