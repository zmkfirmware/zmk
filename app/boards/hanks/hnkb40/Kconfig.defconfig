if BOARD_HNKB40

config ZMK_KEYBOARD_NAME
    default "hnkb40"

# This enables the core ZMK logic for the board
config ZMK
    bool
    default y

if USB_DEVICE_STACK
config USB_NRFX
    default y
endif

if ZMK_STUDIO

config ZMK_STUDIO_LOCKING
    default y

endif # ZMK_STUDIO

endif # BOARD_HNKB40